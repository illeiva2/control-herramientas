<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS + HttpPlatformHandler para servir la app Flask con waitress.
  IMPORTANTE: reemplazá  C:\panol  por la carpeta real donde copiaste la app
  en la VM (en las 3 rutas de abajo). El .env con DATABASE_URL debe estar en
  esa misma carpeta.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*"
           modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform stdoutLogEnabled="true"
                  stdoutLogFile="C:\panol\logs\stdout"
                  startupTimeLimit="60"
                  processPath="C:\panol\.venv\Scripts\python.exe"
                  arguments="C:\panol\serve_iis.py">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
