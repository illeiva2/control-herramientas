# Copiá este archivo como  .env  y completá con tus datos de Supabase.
# El archivo .env NO se sube a git (está en .gitignore).
#
# En Supabase: Project Settings -> Database -> Connection string -> URI.
# Recomendado: usar el "Connection pooler" (Transaction mode, puerto 6543)
# para una app web que abre una conexión por request.
#
# Reemplazá [PASSWORD] por la contraseña de la base y el host por el tuyo.

DATABASE_URL=postgresql://postgres.tuproyecto:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
